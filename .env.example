# Mock Mode (no external APIs required)
# Set to "true" to run the app with realistic demo data
MOCK_MODE=false

# Airtable — direct integration (replaces Make.com)
AIRTABLE_TOKEN=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appgyHtu4tSQxWCvz

# SerpAPI — Google search
SERPAPI_KEY=your_serpapi_key

# Google Gemini — AI analysis
GEMINI_API_KEY=your_gemini_api_key

# Agent Mode — set to "true" to enable the evidence-gathering loop
# (Gemini function calling with up to 5 tool calls per URL).
# Set to "false" (default) to use the faster single-shot prompt.
AGENT_MODE=false

# ScrapingBee — used by the agent's retry_with_proxy tool.
# Only needed when AGENT_MODE=true and you want proxy fallback.
# Get a key at https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=

# Make.com — no longer required (archived, see make-blueprints/)
# MAKE_API_KEY=
# MAKE_START_SEARCH_URL=
# MAKE_GET_RESULTS_URL=
# START_SEARCH_URL=
# GET_RESULTS_URL=
