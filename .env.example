# Mock Mode (no external APIs required)
# Set to "true" to run the app with realistic demo data
MOCK_MODE=false

# Airtable — direct integration (replaces Make.com)
AIRTABLE_TOKEN=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appgyHtu4tSQxWCvz

# SerpAPI — Google search
SERPAPI_KEY=your_serpapi_key

# Google Gemini — AI analysis
GEMINI_API_KEY=your_gemini_api_key

# Optional — enables the evidence-gathering agent loop (recommended)
AGENT_MODE=true

# Optional — required for proxy-based scraping when sites block direct requests
# Get your key at https://www.scrapingbee.com
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key

# Make.com — no longer required (archived, see make-blueprints/)
# MAKE_API_KEY=
# MAKE_START_SEARCH_URL=
# MAKE_GET_RESULTS_URL=
# START_SEARCH_URL=
# GET_RESULTS_URL=
